{
  "name": "cafe-plugins",
  "version": "1.0.0",
  "description": "Loja de plugins Minecraft com backend Turso + Brevo + Mercado Pago/AbacatePay + GitHub Releases. Frontend e backend deploy no Vercel.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node api/server.js",
    "dev": "node --watch api/server.js",
    "test": "node --test",
    "lint": "eslint api/ packages/ public/js/",
    "lint:fix": "eslint --fix api/ packages/ public/js/",
    "format": "prettier --write \"api/**/*.js\" \"packages/**/*.js\" \"public/**/*.js\""
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "api-core": "file:./packages/api-core",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "prettier": "^3.9.5",
    "vercel": "^54.21.1"
  }
}
