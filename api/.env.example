# =====================================================
# Configuração de produção — copie este arquivo para api/.env e preencha os valores
# NUNCA commite o arquivo real (.env); ele já está no .gitignore.
# =====================================================

NODE_ENV=production
APP_URL=https://cafeplugins.com
CORS_ORIGIN=https://cafeplugins.com,https://www.cafeplugins.com

# --- Banco (Turso) ---
TURSO_URL=
TURSO_TOKEN=

# --- Autenticação ---
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
ADMIN_EMAIL=admin@cafeplugins.com
# Mínimo 12 caracteres em produção
ADMIN_PASSWORD=

# --- E-mail (Brevo) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@cafeplugins.com
BREVO_SENDER_NAME=cafe plugins

# --- Gateway de pagamento ---
# Para forçar um gateway: mercadopago | abacate
PAYMENT_GATEWAY=mercadopago

# --- Mercado Pago ---
# Access Token da aplicação de produção (conta real de vendedor, NÃO conta de teste)
MERCADOPAGO_ACCESS_TOKEN=
# Webhook secret (x-signature) gerado no painel do Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SANDBOX=false
MERCADOPAGO_URL=https://api.mercadopago.com

# --- AbacatePay (alternativa de PIX) ---
ABACATE_API_KEY=
ABACATE_WEBHOOK_SECRET=
ABACATE_URL=https://api.abacatepay.com/v2

# --- Configurações de negócio ---
GATEWAY_FEE_FIXED=0.80
TAX_RATE=0
AFFILIATE_NET_COMMISSION=true
MIN_PAYOUT=10
MAX_MANUAL_COMMISSION=10000

# --- Sistema de licenças de plugins (SDK Java) ---
# Gere um par de chaves RS256 e cole as duas no formato PEM.
# Comando:
# node -e "const { generateKeyPairSync } = require('crypto'); const k = generateKeyPairSync('rsa',{modulusLength:2048,privateKeyEncoding:{type:'pkcs8',format:'pem'},publicKeyEncoding:{type:'spki',format:'pem'}}); console.log('---PRIVATE---\n'+k.privateKey); console.log('---PUBLIC---\n'+k.publicKey);"
LICENSE_PRIVATE_KEY=
LICENSE_PUBLIC_KEY=
LICENSE_TOKEN_TTL=7d
LICENSE_ACTIVATION_LIMIT=1

# --- Fallback manual de PIX (só se nenhum gateway estiver configurado) ---
MANUAL_PIX_KEY=

# --- GitHub (só para upload de novos plugins via painel admin) ---
GITHUB_TOKEN=

PORT=3000
